#!/usr/bin/env bash
# USAGE: git-heatmap [git log args...]
# DESCRIPTION: Print a commit heatmap: 7 columns (Sun-Sat) x 24 rows (hour of day).
# Brighter green means more commits in that day/hour bucket. Args pass through to git log
# for filtering, e.g. git-heatmap --author="$USER" --since='1 year ago'.

# ==============================================================================
# COUNT COMMITS
# ==============================================================================
# Bucket commits by local weekday/hour. %w is weekday 0=Sun..6=Sat, %H is the hour.
git_log_args=()
git_log_args+=(--no-merges)
git_log_args+=(--date=format-local:'%w %H')
git_log_args+=(--pretty=format:'%ad')

git_output="$(git log "$@" "${git_log_args[@]}")"
if [[ $? -ne 0 ]]; then
	echo "git-heatmap: git log failed" 1>&2
	exit 1
fi

declare -A commits_per_bucket
max_commits=0
while read -r weekday hour; do
	[[ -z "$weekday" ]] && continue
	bucket_key="$weekday $hour"
	commits_per_bucket["$bucket_key"]=$(( ${commits_per_bucket["$bucket_key"]:-0} + 1 ))
	(( commits_per_bucket["$bucket_key"] > max_commits )) && max_commits=${commits_per_bucket["$bucket_key"]}
done <<< "$git_output"

if (( max_commits == 0 )); then
	echo "git-heatmap: no commits matched" 1>&2
	exit 0
fi

# ==============================================================================
# HELPERS
# ==============================================================================
# Map a commit count to a green-background cell via a dark->bright ramp.
# Empty buckets render as a faint gray block so the grid stays legible.
function cell() {
	local num_commits="$1" green
	if (( num_commits == 0 )); then
		printf '\e[48;2;30;30;30m  \e[0m'
		return
	fi
	# Scale 1..max into green 80..255 so even a single commit is clearly visible.
	green=$(( 80 + (num_commits - 1) * 175 / (max_commits > 1 ? max_commits - 1 : 1) ))
	printf '\e[48;2;0;%d;0m  \e[0m' "$green"
}

# ==============================================================================
# RENDER
# ==============================================================================
days=(S M T W T F S)

printf '    '
for day in "${days[@]}"; do
	printf '%-3s' "$day"
done
printf '\n'

for hour in $(seq 0 23); do
	printf -v hour_key '%02d' "$hour"
	printf '%s  ' "$hour_key"
	for weekday in 0 1 2 3 4 5 6; do
		cell "${commits_per_bucket["$weekday $hour_key"]:-0}"
		printf ' '
	done
	printf '\n'
done

printf '\nmax commits in a bucket: %d\n' "$max_commits"
