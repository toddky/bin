#!/usr/bin/env bash
# USAGE: oc-ls
# DESCRIPTION: List all tmux panes running OpenCode instances

set -euo pipefail

# Performance: Start with ~20 opencode PIDs and find their panes, instead of checking 300+ tmux panes for opencode.
# Uses one `ps` call to build a parent map (0.5s) rather than reading /proc hundreds of times (2-3s).
# Total runtime: ~1.7s.

# Get all opencode PIDs and their working directories
declare -A oc_pids
while read pid; do
    cmdline=$(tr '\0' ' ' < "/proc/$pid/cmdline" 2>/dev/null || true)
    if [[ "$cmdline" == *opencode* ]] && \
       [[ "$cmdline" != *langserver* ]] && \
       [[ "$cmdline" != *language-server* ]] && \
       [[ "$cmdline" != *oc-ls* ]]; then
        cwd=$(readlink "/proc/$pid/cwd" 2>/dev/null || echo "?")
        oc_pids[$pid]="$cwd"
    fi
done < <(pgrep -x opencode 2>/dev/null || true)

[[ ${#oc_pids[@]} -eq 0 ]] && { echo "No OpenCode instances found" >&2; exit 1; }

# Get session titles from OpenCode's database
declare -A titles
db="$HOME/.local/share/opencode/opencode.db"
if [[ -f "$db" ]]; then
    while IFS='|' read -r dir title; do
        titles["$dir"]="$title"
    done < <(sqlite3 "$db" "SELECT directory, title FROM session ORDER BY time_updated DESC" 2>/dev/null)
fi

# Get all tmux panes indexed by their shell PID
declare -A pane_info
while IFS=$'	' read -r pane_pid pane_id pane dims; do
    pane_info[$pane_pid]="$pane_id	$pane	$dims"
done < <(tmux list-panes -a -F "#{pane_pid}	#{pane_id}	#{session_name}:#{window_index}.#{pane_index}	#{pane_width}x#{pane_height}" 2>/dev/null)

# Build parent map for all processes (one ps call)
declare -A parents
while read pid ppid; do
    parents[$pid]=$ppid
done < <(ps -eo pid,ppid)

# For each opencode instance, walk up parents to find its tmux pane
found=0
for oc_pid in "${!oc_pids[@]}"; do
    cwd="${oc_pids[$oc_pid]}"
    
    # Walk up the process tree until we find a tmux pane
    pid=$oc_pid
    while [[ $pid -gt 1 ]]; do
        if [[ -n "${pane_info[$pid]:-}" ]]; then
            IFS=$'	' read -r pane_id pane dims <<< "${pane_info[$pid]}"
            title="${titles[$cwd]:-}"
            
            if [[ -n "$title" ]]; then
                printf "%-8s %-20s %-10s %-50s %s\n" "$pane_id" "$pane" "$dims" "$title" "$cwd"
            else
                printf "%-8s %-20s %-10s %s\n" "$pane_id" "$pane" "$dims" "$cwd"
            fi
            found=1
            break
        fi
        pid=${parents[$pid]:-0}
    done
    done
done

if (( found == 0 )); then
    echo "No OpenCode panes found" >&2
    exit 1
fi
