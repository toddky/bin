#!/usr/bin/env bash
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

# https://patrickmccanna.net/a-better-way-to-limit-claude-code-and-other-coding-agents-access-to-secrets/
bwrap_args=()
# Mount host /usr read-only -- bare minimum for binaries and libraries to exist inside the sandbox.
bwrap_args+=(--ro-bind /usr /usr)
# Programs expect /lib, /lib64, /bin at the root; these symlinks redirect them into /usr.
bwrap_args+=(--symlink usr/lib /lib)
bwrap_args+=(--symlink usr/lib64 /lib64)
bwrap_args+=(--symlink usr/bin /bin)
# /proc and /dev are needed by most programs; many syscalls fail without them.
bwrap_args+=(--proc /proc)
bwrap_args+=(--dev /dev)
# Isolated /tmp so sandbox writes don't leak to host.
bwrap_args+=(--tmpfs /tmp)
# DNS and hostname resolution -- needed if --share-net is ever added.
bwrap_args+=(--ro-bind /etc/resolv.conf /etc/resolv.conf)
bwrap_args+=(--ro-bind /etc/hosts /etc/hosts)
# uid/gid name resolution -- prevents whoami/groups errors inside the sandbox.
bwrap_args+=(--ro-bind /etc/passwd /etc/passwd)
bwrap_args+=(--ro-bind /etc/group /etc/group)
# NSS config -- tells libc which lookup modules to use (files, sss, etc.).
bwrap_args+=(--ro-bind /etc/nsswitch.conf /etc/nsswitch.conf)
# LDAP/AD uid/gid lookups go through SSSD -- bind the NSS socket so whoami works for domain users.
[[ -S /var/lib/sss/pipes/nss ]] && bwrap_args+=(--bind /var/lib/sss/pipes/nss /var/lib/sss/pipes/nss)
# Drop all namespace sharing (network, IPC, mount points, etc.).
bwrap_args+=(--unshare-all)
# Kill the sandbox if the parent process dies to prevent orphaned processes.
bwrap_args+=(--die-with-parent)

cmd=("${SHELL:-/bin/sh}")
[[ $# -gt 0 ]] && cmd=("$@")

exec bwrap "${bwrap_args[@]}" "${cmd[@]}"
